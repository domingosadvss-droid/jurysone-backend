# Jurysone — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# ─── Banco de Dados ────────────────────────────────────────────────────────────
DB_PASS=jurysone_dev
DATABASE_URL=postgresql://jurysone:jurysone_dev@localhost:5432/jurysone_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=troque_este_segredo_em_producao_use_32_chars_ou_mais
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_EXPIRES_DAYS=30

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=troque_este_segredo_nextauth_em_producao

# ─── OpenAI (Copiloto Jurídico) ───────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-sua_chave_openai_aqui

# ─── E-mail (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_sua_chave_resend_aqui
EMAIL_FROM=noreply@jurysone.com.br

# ─── AWS S3 (Documentos) ──────────────────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_S3_BUCKET=jurysone-documents

# ─── Stripe (Billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_sua_chave_stripe
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_webhook

# ─── WhatsApp (Opcional) ──────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=seu_token_whatsapp_business

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=development
