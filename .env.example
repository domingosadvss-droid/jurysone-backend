# ════════════════════════════════════════════════════════════════════════════════
# JURYSONE — Variáveis de Ambiente
# ════════════════════════════════════════════════════════════════════════════════
# Cópie este arquivo para .env local e preencha os valores
# Para Render/Produção: Configure estas variáveis no dashboard do Render
# ════════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────────
# 🔴 VARIÁVEIS CRÍTICAS (Necessárias para funcionamento)
# ──────────────────────────────────────────────────────────────────────────────────

# Node Environment
NODE_ENV=development
PORT=3001

# ── Banco de Dados (Supabase/PostgreSQL) ──
# Obtenha em: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres.xxxxx:SENHA@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxx:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# ── JWT (Autenticação) ──
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta_jwt_super_secreta_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=3600

# ── Frontend URL (CORS) ──
FRONTEND_URL=http://localhost:8000

# ── Supabase Storage ──
# Obtenha em: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────────────────────────────────────────
# 🟡 VARIÁVEIS IMPORTANTES (Altamente recomendadas)
# ──────────────────────────────────────────────────────────────────────────────────

# ── IA (Google Gemini 1.5 Flash) ──
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── E-mail (Resend) ──
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_sua_chave_resend_aqui
EMAIL_FROM=noreply@jurysone.com.br

# ── Redis (Cache + Job Queue) ──
# Formato: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────────────────────
# 🟢 VARIÁVEIS OPCIONAIS (Configure conforme necessário)
# ──────────────────────────────────────────────────────────────────────────────────

# ── Google Calendar Integration ──
# Obtenha em: Google Cloud Console → OAuth 2.0 Client IDs
# Setup guide: GOOGLE_CALENDAR_SETUP.md
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ── AWS S3 (Armazenamento de Documentos) ──
# Obtenha em: AWS Console → IAM → Security Credentials
# AWS_REGION=sa-east-1
# AWS_ACCESS_KEY_ID=sua_access_key
# AWS_SECRET_ACCESS_KEY=sua_secret_key
# AWS_S3_BUCKET=jurysone-documents

# ── Stripe (Pagamentos) ──
# Obtenha em: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_sua_chave_stripe
# STRIPE_WEBHOOK_SECRET=whsec_sua_chave_webhook

# ── WhatsApp Integration (Meta API) ──
# Obtenha em: https://developers.facebook.com/ → WhatsApp
# Setup guide: WHATSAPP_META_SETUP.md
WHATSAPP_BUSINESS_ACCOUNT_ID=seu_business_account_id
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_API_TOKEN=EAABs...seu_access_token
WHATSAPP_VERIFY_TOKEN=token_aleatorio_seu_webhook
WHATSAPP_API_URL=https://graph.instagram.com/v18.0

# ── DataJud (Consulta de Processos Judiciais) ──
# Obtenha em: https://www.cnj.jus.br/programas-e-acoes/datajud
# DATAJUD_API_KEY=sua_chave_datajud

# ── E-mail Alternativo (Nodemailer - fallback) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASS=sua_senha_app_google

# ──────────────────────────────────────────────────────────────────────────────────
# 📋 RESUMO DAS VARIÁVEIS
# ──────────────────────────────────────────────────────────────────────────────────
#
# CRÍTICAS (15):
#   NODE_ENV, PORT, DATABASE_URL, DIRECT_URL, JWT_SECRET, JWT_EXPIRES_IN,
#   FRONTEND_URL, SUPABASE_URL, SUPABASE_SERVICE_KEY, GEMINI_API_KEY,
#   RESEND_API_KEY, EMAIL_FROM, REDIS_URL
#
# OPCIONAIS (11):
#   GOOGLE_CLIENT_ID/SECRET/REDIRECT_URI, AWS_*, STRIPE_*, WHATSAPP_*,
#   DATAJUD_API_KEY, SMTP_*
#
# ────────────────────────────────────────────────────────────────────────────────
