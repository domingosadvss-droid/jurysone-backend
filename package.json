{
  "name": "jurysone-backend",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "schema": "src/database/schema.prisma"
  },
  "scripts": {
    "postinstall": "prisma generate --schema src/database/schema.prisma",
    "dev": "prisma generate --schema src/database/schema.prisma && nest start --watch",
    "setup": "prisma generate --schema src/database/schema.prisma && prisma migrate dev --name init --schema src/database/schema.prisma && nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev --schema src/database/schema.prisma",
    "db:generate": "prisma generate --schema src/database/schema.prisma",
    "db:seed": "ts-node src/database/seeds/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/cache-manager": "^2.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "@supabase/supabase-js": "^2.100.1",
    "argon2": "^0.40.0",
    "axios": "^1.7.0",
    "bull": "^4.16.0",
    "cache-manager": "^5.0.0",
    "cache-manager-redis-store": "^3.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cron": "^3.0.0",
    "dayjs": "^1.11.0",
    "docx": "^9.6.1",
    "form-data": "^4.0.0",
    "googleapis": "^140.0.1",
    "helmet": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.0",
    "qrcode": "^1.5.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^3.0.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.33.0",
    "socket.io": "^4.7.0",
    "stripe": "^14.0.0",
    "uuid": "^10.0.0",
    "web-push": "^3.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "jest": "^29.0.0",
    "prisma": "^5.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}
